<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <!-- ═══ Connection Strings ═══════════════════════════════════════════ -->
  <connectionStrings>
    <!--
      Replace HOST, PORT, SERVICE_NAME, User Id, and Password with your values.
      Example for TNS alias:
        Data Source=MYDB;User Id=myuser;Password=mypass;
    -->
    <add name="OracleDb"
         connectionString="Data Source=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=YOUR_HOST)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=YOUR_SERVICE)));User Id=YOUR_USER;Password=YOUR_PASSWORD;"
         providerName="Oracle.ManagedDataAccess.Client" />
  </connectionStrings>

  <!-- ═══ System.Web (ASP.NET Classic) ════════════════════════════════ -->
  <system.web>
    <compilation debug="false" targetFramework="4.5" />
    <httpRuntime targetFramework="4.5" maxRequestLength="10240" />
  </system.web>

  <!-- ═══ IIS / System.WebServer ══════════════════════════════════════ -->
  <system.webServer>
    <validation validateIntegratedModeConfiguration="false" />
    <handlers>
      <remove name="ExtensionlessUrlHandler-Integrated-4.0" />
      <remove name="OPTIONSVerbHandler" />
      <remove name="TRACEVerbHandler" />
      <add name="ExtensionlessUrlHandler-Integrated-4.0"
           path="*."
           verb="*"
           type="System.Web.Handlers.TransferRequestHandler"
           preCondition="integratedMode,runtimeVersionv4.0" />
    </handlers>
  </system.webServer>

  <!-- ═══ Oracle Managed Data Access ══════════════════════════════════ -->
  <oracle.manageddataaccess.client>
    <version number="*">
      <settings>
        <setting name="TNS_ADMIN" value="" />
      </settings>
    </version>
  </oracle.manageddataaccess.client>

</configuration>
